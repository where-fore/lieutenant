; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Lieutenant"
run/main_scene="uid://m6cv5sqf20gx"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

HudEvents="*res://scripts/autoload/hud_events.gd"
CombatEvents="*res://scripts/autoload/combat_events.gd"
AuraEvents="*res://scripts/autoload/aura_events.gd"
CombatLogEvents="*res://scripts/autoload/combat_log_events.gd"
InventoryEvents="*res://scripts/autoload/inventory_events.gd"
TimingEvents="*res://scripts/autoload/timing_events.gd"
Stats="*res://scripts/autoload/stat_names.gd"
AuraNames="*res://scripts/autoload/aura_names.gd"

[debug]

gdscript/warnings/untyped_declaration=1
gdscript/warnings/inferred_declaration=1

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
mouse_cursor/tooltip_position_offset=Vector2(0, 32)

[gui]

timers/tooltip_delay_sec=0.0
theme/custom="uid://wymfijcko1gs"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
